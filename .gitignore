# ==========================================
# 1. Bases de datos y archivos pesados (¡La causa de los 1.3 GB!)
# ==========================================
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.json
*.sql
# Si tienes una carpeta específica para tus datos, ignórala completa:
data/
datasets/

# ==========================================
# 2. Modelos de Machine Learning guardados
# ==========================================
*.pkl
*.joblib
*.h5
*.model
*.cbm      # Modelos de CatBoost
*.txt      # Si LightGBM guarda el modelo en texto

# ==========================================
# 3. Entornos Virtuales de Python
# ==========================================
venv/
env/
.env/
.venv/
.conda/
Include/
Lib/
Scripts/

# ==========================================
# 4. Archivos temporales de Python y Jupyter
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# ==========================================
# 5. Variables de entorno (Contraseñas de bases de datos, etc.)
# ==========================================
.env

# ==========================================
# 6. Archivos del Sistema Operativo
# ==========================================
.DS_Store
Thumbs.dboutput/*.jsonl 
output/ 
