DB_HOST=localhost
DB_PORT=5432
DB_NAME=kapak
DB_USER=tu_usuario
DB_PASSWORD=tu_password

OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-large

# Rango de fechas de fecha_de_publicacion (inclusive)
START_DATE=2022-01-01
END_DATE=2022-12-31
PROCESS_LIMIT=10

# Tamaño de lote para la API de embeddings
BATCH_SIZE=100
EMBEDDING_CACHE_FILE=./Codes/output/embedding_cache_text-embedding-3-large.jsonl
INCLUDE_LABEL_COLUMN=false
LABEL_VALUE=0

# Carpeta de salida
OUTPUT_DIR=./Codes/output
